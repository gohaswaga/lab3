create procedure quantity_subjects
    @fpk_count int output,
    @fpm_count int output,
    @total_count int output,
    @identical_count int output
as
begin
    select @fpk_count = count(distinct s.id)
    from faculty f
    join [hours] h on f.id = h.faculty_id
    join work w on h.id = w.hours_id
    join subj s on w.subj_id = s.id
    where f.faculty_name = 'ФПК'

    select @fpm_count = count(distinct s.id)
    from faculty f
    join [hours] h on f.id = h.faculty_id
    join work w on h.id = w.hours_id
    join subj s on w.subj_id = s.id
    where f.faculty_name = 'ФПМ'

    select @total_count = count(distinct s.id)
    from subj s
    join work w on s.id = w.subj_id
    join [hours] h on w.hours_id = h.id
    join faculty f on h.faculty_id = f.id
    where f.faculty_name in ('ФПК', 'ФПМ')

    select @identical_count = count(distinct s.id)
    from subj s
    where exists (
        select 1
        from work w1
        join [hours] h1 on w1.hours_id = h1.id
        join faculty f1 on h1.faculty_id = f1.id
        where w1.subj_id = s.id
          and f1.faculty_name = 'ФПК'
    )
    and exists (
        select 1
        from work w2
        join [hours] h2 on w2.hours_id = h2.id
        join faculty f2 on h2.faculty_id = f2.id
        where w2.subj_id = s.id
          and f2.faculty_name = 'ФПМ'
    )

    if @identical_count is null
        set @identical_count = 0

    print 'Для ФПК читается ' + cast(@fpk_count as nvarchar(10)) + ' предметов'
    print 'Для ФПМ читается ' + cast(@fpm_count as nvarchar(10)) + ' предметов'
    print 'Всего ' + cast(@total_count as nvarchar(10)) + ' предметов ( ' + cast(@identical_count as nvarchar(10)) + ' из которых идентичны)'
end

declare @fpk int, @fpm int, @total int, @identical int
exec quantity_subjects
    @fpk_count = @fpk output,
    @fpm_count = @fpm output,
    @total_count = @total output,
    @identical_count = @identical output

drop procedure if exists quantity_subjects

