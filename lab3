create procedure sp_count_students_by_faculty_and_form
    @faculty_name nvarchar(50),
    @form_name nvarchar(30)
as
begin
    declare @student_count int

    select @student_count = count(distinct s.id)
    from faculty f
    join [hours] h on f.id = h.faculty_id
    join form fm on h.form_id = fm.id
    join process p on h.id = p.hours_id
    join stud s on p.stud_id = s.id
    where f.faculty_name = @faculty_name
      and fm.form_name = @form_name

    print 'факультет: ' + @faculty_name
    print 'форма обучения: ' + @form_name
    print 'количество студентов: ' + cast(isnull(@student_count, 0) as nvarchar(10))
end
