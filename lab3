create function dbo.GetLoad(@teach_id int)
returns int
as
begin
    declare @total_hours int
    
    select @total_hours = sum(s.[hours])
    from teach t
    join work w on t.id = w.teach_id
    join subj s on w.subj_id = s.id
    join hours h on w.hours_id = h.id
    where t.id = @teach_id
    
    return isnull(@total_hours, 0)
end

select 
    t.last_name,
    t.f_name,
    t.s_name,
    dbo.GetLoad(t.id) as total_hours
from teach t


