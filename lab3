create database BOSTON

use BOSTON

create table faculty(
    id int identity(1,1) primary key,
    faculty_name nvarchar(50)
);

create table form(
    id int identity(1,1) primary key, 
    form_name nvarchar(30)
);

create table stud(
    id int identity(1,1) primary key,
    last_name nvarchar(30),
    f_name nvarchar(30),
    s_name nvarchar(30),
    br_date date,
    in_date date,
    exm int 
);

create table teach(
    id int identity(1,1) primary key,
    last_name nvarchar(30),
    f_name nvarchar(30),
    s_name nvarchar(30),
    br_date date,
    start_work_date date
);

create table subj(
    id int identity(1,1) primary key,
    subj nvarchar(100),
    [hours] int
);

create table [hours](
    id int identity(1,1) primary key,
    cours int,
    faculty_id int foreign key references faculty(id),
    form_id int foreign key references form(id),   
    all_h int,
    inclass_h int
);

create table process(
    stud_id int foreign key references stud(id),   
    hours_id int foreign key references [hours](id),
    primary key (stud_id, hours_id) 
);
 
create table work(
    teach_id int foreign key references teach(id),
    subj_id int foreign key references subj(id),
    hours_id int foreign key references [hours](id),
    primary key (teach_id, subj_id, hours_id)
);

--selecтусы
--1

select f.id as faculty_id, f.faculty_name, avg(s.exm * 1.0) as avg_exm
from stud s
join process p on s.id = p.stud_id
join [hours] h on p.hours_id = h.id
join faculty f on h.faculty_id = f.id
join form fm on h.form_id = fm.id
where fm.form_name = 'заочная'
group by f.id, f.faculty_name
order by f.id;

--2

select 
    faculty_id,
    faculty_name,
    max(avg_score) as max_avg
from (
    select f.id as faculty_id, f.faculty_name, h.cours, avg(s.exm * 1.0) as avg_score
    from stud s
    join process p on s.id = p.stud_id
    join [hours] h on p.hours_id = h.id
    join faculty f on h.faculty_id = f.id
    group by f.id, f.faculty_name, h.cours
) as course_avg
group by faculty_id, faculty_name
order by faculty_id;

--3

select f.id as faculty_id, f.faculty_name, avg(s.exm * 1.0) as avg_exam
from stud s
join process p on s.id = p.stud_id
join [hours] h on p.hours_id = h.id
join faculty f on h.faculty_id = f.id
group by f.id, f.faculty_name
having avg(s.exm * 1.0) > 7
order by avg_exam desc;

--4

select h.cours, f.faculty_name, fm.form_name, avg(s.exm * 1.0) as avg_exam
from stud s
join process p on s.id = p.stud_id
join [hours] h on p.hours_id = h.id
join faculty f on h.faculty_id = f.id
join form fm on h.form_id = fm.id
where s.exm is not null
group by h.cours, f.faculty_name, fm.form_name
having avg(s.exm * 1.0) > 7.5
order by avg_exam desc;

--5

select f.faculty_name, h.cours, avg(s.exm * 1.0) as avg_score, min(avg(s.exm * 1.0)) over(partition by f.id) as min_avg_on_faculty
from stud s
join process p on s.id = p.stud_id
join [hours] h on p.hours_id = h.id
join faculty f on h.faculty_id = f.id
where s.exm is not null
group by f.id, f.faculty_name, h.cours
order by f.id, avg_score;

--6

select f.id as faculty_id, f.faculty_name, fm.form_name, min(avg_score) as min_avg
from (
    select h.faculty_id, h.form_id, h.cours, avg(s.exm * 1.0) as avg_score
    from stud s
    join process p on s.id = p.stud_id
    join [hours] h on p.hours_id = h.id
    group by h.faculty_id, h.form_id, h.cours
) as course_avg
join faculty f on course_avg.faculty_id = f.id
join form fm on course_avg.form_id = fm.id
group by f.id, f.faculty_name, fm.form_name
having min(avg_score) > 6
order by f.id, fm.form_name;

--7

select s.id as student_id, s.last_name, s.f_name, s.s_name, h.all_h - h.inclass_h as self_study_hours
from stud s
join process p on s.id = p.stud_id
join [hours] h on p.hours_id = h.id
join faculty f on h.faculty_id = f.id
join form fm on h.form_id = fm.id
where f.faculty_name = 'ФПК'
  and h.cours = 3
  and fm.form_name = 'заочная';

--8

select f.id as faculty_id, f.faculty_name, h.cours, fm.form_name, (h.all_h - h.inclass_h) as self_study_hours
from [hours] h
join faculty f on h.faculty_id = f.id
join form fm on h.form_id = fm.id
where (h.all_h - h.inclass_h) > 150
order by self_study_hours desc, f.faculty_name, h.cours;

--9

select t.id as teacher_id, t.last_name, t.f_name, t.s_name, count(w.subj_id) as subjects
from teach t
left join work w on t.id = w.teach_id
group by t.id, t.last_name, t.f_name, t.s_name
order by subjects desc, t.last_name;

--10

select f.id as faculty_id, f.faculty_name, count(distinct t.id) as teachers_quantity
from faculty f
left join [hours] h on f.id = h.faculty_id
left join work w on h.id = w.hours_id
left join teach t on w.teach_id = t.id
group by f.id, f.faculty_name
order by teachers_quantity desc, f.faculty_name;

--11

select s.id as subject_id, s.subj, max(h.all_h) as max_hours
from subj s
join work w on s.id = w.subj_id
join [hours] h on w.hours_id = h.id
group by s.id, s.subj
order by max_hours desc;

--12

select t.id as teacher_id, t.last_name, t.f_name, t.s_name, count(w.subj_id) as subject_quantity
from teach t
join work w on t.id = w.teach_id
group by t.id, t.last_name, t.f_name, t.s_name
having count(w.subj_id) > 1
order by subject_quantity desc, t.last_name;

--13

select f.id as faculty_id, f.faculty_name, h.cours, sum(h.all_h) as total_hours
from [hours] h
join faculty f on h.faculty_id = f.id
group by f.id, f.faculty_name, h.cours
order by f.id, h.cours;

--14

select f.faculty_name, h.cours, count(s.id) as subject_quantity
from faculty f
join [hours] h on f.id = h.faculty_id
join work w on h.id = w.hours_id
join subj s on w.subj_id = s.id
where h.cours = 2
group by f.faculty_name, h.cours
order by f.faculty_name desc, h.cours asc

--15

select f.faculty_name, count(distinct s.id) as subject_quantity
from faculty f
join [hours] h on f.id = h.faculty_id
join work w on h.id = w.hours_id
join subj s on w.subj_id = s.id
join teach t on w.teach_id = t.id
where t.f_name is null
group by f.faculty_name
order by f.faculty_name

--joinсы
--1

select s.last_name, s.f_name, s.s_name, s.br_date, f.faculty_name, h.cours, fm.form_name
