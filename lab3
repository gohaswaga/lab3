create view low_statistics_students as
select s.last_name, s.f_name, s.s_name, h.cours, fac.faculty_name, f.form_name, avg(cast(s.exm as float)) as avg_score
from stud s
join process p on s.id = p.stud_id
join hours h on p.hours_id = h.id
join faculty fac on h.faculty_id = fac.id
join form f on h.form_id = f.id
where s.exm < 6
group by s.last_name, s.f_name, s.s_name, h.cours, fac.faculty_name, f.form_name

