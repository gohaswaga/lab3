create function dbo.GetStatus(@s_name nvarchar(30))
returns nvarchar(20)
as
begin
    declare @result nvarchar(20)
    
    if exists (select 1 from stud where s_name = @s_name and f_name is null)
        set @result = 'иностранец'
    else
        set @result = 'гражданин'
    
    return @result
end

