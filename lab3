create procedure add_student
    @last_name nvarchar(30),
    @first_name nvarchar(30),
    @surname nvarchar(30),
    @birth_date date,
    @admission_date date,
    @faculty_name nvarchar(50),
    @form_name nvarchar(30)
as
begin
    set nocount on
    
    declare @faculty_id int
    declare @form_id int
    declare @hours_id int
    declare @student_id int
    declare @error_message nvarchar(50)

    select @faculty_id = id from faculty where faculty_name = @faculty_name
    
    if @faculty_id is null
    begin
        set @error_message = 'ошибка: факультет "' + @faculty_name + '" не существует'
        print @error_message
        raiserror(@error_message, 16, 1)
        return
    end

    select @form_id = id from form where form_name = @form_name
    
    if @form_id is null
    begin
        set @error_message = 'ошибка: форма обучения "' + @form_name + '" не существует'
        print @error_message
        raiserror(@error_message, 16, 1)
        return
    end

    select @hours_id = id 
    from [hours] 
    where faculty_id = @faculty_id 
      and form_id = @form_id 
      and cours = 1
    
    if @hours_id is null
    begin
        set @error_message = 'ошибка: комбинация факультет "' + @faculty_name + 
                             '", форма "' + @form_name + '", курс 1 не существует'
        print @error_message
        raiserror(@error_message, 16, 1)
        return
    end

    insert into stud (last_name, f_name, s_name, br_date, in_date, exm)
    values (@last_name, @first_name, @surname, @birth_date, @admission_date, null)

    set @student_id = scope_identity()

    insert into process (stud_id, hours_id)
    values (@student_id, @hours_id)

    print 'студент успешно добавлен'
    print 'фамилия: ' + @last_name
    print 'имя: ' + @first_name
    print 'отчество: ' + isnull(@surname, '')
    print 'факультет: ' + @faculty_name
    print 'форма обучения: ' + @form_name
    print 'курс: 1'
    print 'дата рождения: ' + cast(@birth_date as nvarchar(20))
    print 'дата поступления: ' + cast(@admission_date as nvarchar(20))
end

exec add_student
    @last_name = 'Иванов',
    @first_name = 'Петр',
    @surname = 'Сергеевич',
    @birth_date = '2005-05-15',
    @admission_date = '2024-09-01',
    @faculty_name = 'медицинский',
    @form_name = 'очная'

drop procedure if exists add_student

